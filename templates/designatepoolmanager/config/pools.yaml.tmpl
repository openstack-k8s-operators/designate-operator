---
{{- range . }}
- name: {{.Name}}
  description: {{.Description}}
  attributes: {
    {{- range $key, $value := .Attributes }}
    "{{ $key }}": "{{ $value }}",
    {{- end }}
  }

  ns_records:
    {{- range .NSRecords }}
    - hostname: {{.Hostname}}
      priority: {{.Priority}}
    {{- end }}

  nameservers:
    {{- range .Nameservers }}
    - host: {{.Host}}
      port: {{.Port}}
      {{- if .TSIGKeyID }}
      tsigkey_id: {{.TSIGKeyID}}
      {{- end }}
    {{- end }}

  targets:
    {{- range .Targets }}
    - type: {{.Type}}
      description: {{.Description}}
      {{- if .TSIGKeyID }}
      tsigkey_id: {{.TSIGKeyID}}
      {{- end }}

      masters:
        {{- range .Masters }}
        - host: {{.Host}}
          port: {{.Port}}
        {{- end }}

      options:
        host: {{.Options.Host}}
        port: {{.Options.Port}}
        rndc_host: {{.Options.RNDCHost}}
        rndc_port: {{.Options.RNDCPort}}
        rndc_key_file: {{.Options.RNDCKeyFile}}
        {{- if .Options.View }}
        view: {{.Options.View}}
        {{- end }}
    {{- end }}

  {{- if .CatalogZone }}
  catalog_zone:
    catalog_zone_fqdn: {{.CatalogZone.FQDN}}
    catalog_zone_refresh: '{{.CatalogZone.Refresh}}'
  {{- end }}
{{- end }}
